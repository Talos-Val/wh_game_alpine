def read_multiline(prompt: str) -> str:
    print(c(Col.CYAN, prompt), end="", flush=True)
    lines = []
    try:
        while True:
            line = input()
            if line.strip() == "" and lines:
                break
            lines.append(line)
    except EOFError:
        pass
    return "\n".join(lines)

def repl():
    print_banner()
    while True:
        try:
            raw = read_multiline(
                "┌─ Plan / Aussage eingeben (Leerzeile zum Analysieren):\n└▶ "
            )
        except KeyboardInterrupt:
            print(c(Col.DIM, "\n  [Strg+C] — 'quit' zum Beenden"))
            continue

        cmd = raw.strip().lower()

        if cmd in ("quit", "exit", "q", "bye"):
            print(c(Col.DIM, "\n  Möge dein Plan gelingen.\n"))
            sys.exit(0)
        elif cmd in ("hilfe", "help", "h", "?"):
            print_help()
            continue
        elif cmd in ("neu", "new", "clear"):
            print("\033[2J\033[H", end="")
            print_banner()
            continue
        elif not cmd:
            continue

        result = analyze(raw)
        print_findings(result)
        print_summary(result)


