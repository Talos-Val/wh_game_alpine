            print(f"{C}Erkannter Künstler: {B}{artist_name}{W}")
            confirm = input(f"{Y}» Künstler korrekt? (ENTER = ja, oder neuen Namen eingeben): {W}").strip()
            if confirm:
                artist_name = confirm
        else:
            print(f"{Y}[WARNUNG] Künstler konnte nicht automatisch erkannt werden.{W}")
            artist_name = input(f"{Y}» Künstler/Interpret für den Ordnernamen eingeben: {W}").strip()

        artist_folder = get_safe_filename(artist_name) if artist_name else "Unbekannter_Saenger"
        # Suchquery: Künstler + Titel zusammen — beide Infos für YouTube-Suche
        # (Künstler ist jetzt vom Nutzer bestätigt, also zuverlässig)
        if artist_name and song_title:
            search_query = f"{artist_name} {song_title}"
        else:
            search_query = song_title or artist_name or user_input
        print(f"{C}[INFO] Suchquery: '{search_query}' | Ordner: '{artist_folder}'{W}")
    else:
        # Kein Spotify-Link — Künstler und Titel explizit trennen
        if " - " in user_input:
            parts = user_input.split(" - ", 1)
            artist_name = parts[0].strip()
            song_title = parts[1].strip()
        else:
            # Keine Trennzeichen → getrennt abfragen
            print(f"{Y}[LOG] Kein 'Künstler - Titel' Format erkannt. Bitte getrennt eingeben.{W}")
            artist_name = input(f"{C}» Künstler/Interpret: {W}").strip()
            song_title = input(f"{C}» Songtitel: {W}").strip() or user_input

        artist_folder = get_safe_filename(artist_name) if artist_name else "Unbekannter_Saenger"
        # Suchquery: Künstler + Titel zusammen für präzise Ergebnisse
        if artist_name and song_title:
            search_query = f"{artist_name} {song_title}"
        elif artist_name:
            search_query = artist_name
        else:
            search_query = song_title or user_input
        print(f"{C}[INFO] Suchquery: '{search_query}' | Ordner: '{artist_folder}'{W}")

    target_dir = f"{vault_dir}/Music_Schrein/Kuenstler/{artist_folder}"

    print(f"\n{Y}[LOG] Starte YouTube-Suche (20 Vektoren)...{W}")
    print(f"{C}[SUCHE] Query: '{search_query}'{W}")

    search_opts = {
        'extract_flat': True,
        'quiet': True,
        'http_headers': BROWN_GEAR_HEADERS,
        'user_agent': BROWN_GEAR_HEADERS['User-Agent'],
    }

    yt_search_string = f"ytsearch20:{search_query}"
    
    try:
        with YoutubeDL(search_opts) as ydl:
            search_results = ydl.extract_info(yt_search_string, download=False)
        
        entries = search_results.get('entries', [])
        if not entries:
            print(f"{R}[STÖRUNG] Keine Frequenzen auf YouTube lokalisiert.{W}")
            return

        # ==========================================
        # INTERAKTIVES BLÄTTER-SYSTEM (20 TRACKS MAX)
        # ==========================================
        current_index = 0
        page_size = 5
        chosen_entry = None

        while True:
            print(f"\n{C}Gefundene YouTube-Vektoren (Einträge {current_index + 1} bis {min(current_index + page_size, len(entries))} von {len(entries)}):{W}")
            
            for i in range(current_index, min(current_index + page_size, len(entries))):
                entry = entries[i]
                title = entry.get('title', 'Unbekannter Titel')
                uploader = entry.get('uploader', 'Unbekannter Kanal')
                duration = entry.get('duration', 0)
                
                minutes = int(duration // 60)
                seconds = int(duration % 60)
                duration_str = f"{minutes}:{seconds:02d}" if duration else "Unbekannt"
                
                display_num = (i - current_index) + 1
                print(f" [{Y}{display_num}{W}] {B}{title}{W}")
                print(f"     Kanal: {C}{uploader}{W} | Länge: {C}{duration_str}{W}")

            if current_index + page_size < len(entries):
                print(f"\n[{Y}m{W}] Mehr Ergebnisse anzeigen (weiterblättern)")
            else:
                print(f"\n[{Y}m{W}] Zurück zur ersten Seite springen")
            print(f"[ENTER] Suche abbrechen")
            
            selection = input(f"\n{B}{R}Wähle Vektor (1-5) oder Binärbefehl » {W}").strip().lower()
            
            if not selection:
                print(f"{Y}[LOG] Suche abgebrochen.{W}")
                return
                
            if selection == 'm':
                if current_index + page_size < len(entries):
                    current_index += page_size
                else:
                    print(f"\n{Y}[INFO] Signalkette schließt sich. Zurück auf Anfang.{W}")
                    current_index = 0
                continue
                
            if selection.isdigit():
                num = int(selection)
                if 1 <= num <= min(page_size, len(entries) - current_index):
                    chosen_entry = entries[current_index + num - 1]
                    break
                else:
                    print(f"{R}[STÖRUNG] Ungültiger Index für diese Sektion!{W}")
            else:
                print(f"{R}[STÖRUNG] Unbekannter Steuerbefehl!{W}")

        if not chosen_entry:
            return

        chosen_video_url = chosen_entry.get('url') or f"https://www.youtube.com/watch?v={chosen_entry.get('id')}"
        chosen_title = chosen_entry.get('title')

    except Exception as e:
        print(f"{R}[ABBRUCH] Fehlfunktion bei der Netz-Suche: {e}{W}")
        return

    os.makedirs(target_dir, exist_ok=True)
    print(f"\n{G}[RIEGEL] Ziel verifiziert: '{chosen_title}'{W}")
    print(f"{Y}[LOG] Starte Extraktion des reinen Audio-Kerns...{W}")

    ydl_opts = {
        'format': 'bestaudio/best',
        'outtmpl': f'{target_dir}/%(title)s.%(ext)s',
        'quiet': False,
        'http_headers': BROWN_GEAR_HEADERS,
        'user_agent': BROWN_GEAR_HEADERS['User-Agent'],
    }

    if ffmpeg_available:
        ydl_opts['postprocessors'] = [{
            'key': 'FFmpegExtractAudio',
            'preferredcodec': 'mp3',
            'preferredquality': '320',
        }]

    try:
        with YoutubeDL(ydl_opts) as ydl:
            ydl.download([chosen_video_url])
        print(f"\n{G}✓ [ERFOLG] Track im richtigen Sänger-Ordner versiegelt!{W}")
    except Exception as e:
        print(f"{R}[KATASTROPHE] Download fehlgeschlagen: {e}{W}")

