#!/usr/bin/env python3
import random
import os

STATUS_FILE = "/tmp/squig_status.txt"

def lade_squig():
    if os.path.exists(STATUS_FILE):
        with open(STATUS_FILE, "r") as f:
            daten = f.read().split(",")
            return int(daten[0]), int(daten[1])
    return 50, 50 # Hunger, Laune

def speichere_squig(hunger, laune):
    with open(STATUS_FILE, "w") as f:
        f.write(f"{hunger},{laune}")

def squig_pet():
    hunger, laune = lade_squig()
    
    # Zustand verschlechtern bei jedem Start
    hunger = min(100, hunger + random.randint(5, 15))
    laune = max(0, laune - random.randint(5, 15))
    
    print("🔴 DEIN TERMINAL-SQUIG 🔴")
    if hunger > 80:
        print("    (oO)  *KNURR*")
        print("   <(__)>  Der Squig ist ausgehungert und fletscht die Zähne!")
    elif laune < 30:
        print("    (--)  *SCHMOLL*")
        print("   <(__)>  Der Squig schaut dich böse an.")
    else:
        print("    (==)  *SABBER*")
        print("   <(__)>  Der Squig hüpft fröhlich im Terminal herum.")
        
    print(f"\n📊 Status -> Hunger: {hunger}% | Laune: {laune}%")
    print("Was willst du tun?\n1 - Füttern (Fleischbrocken reinwerfen)\n2 - Streicheln (Vorsichtig wegen den Zähnen)\n3 - Treten (Nicht empfohlen)")
    
    wahl = input("> ").strip()
    if wahl == "1":
        hunger = max(0, hunger - 40)
        laune = min(100, laune + 10)
        print("\n🥩 Mampf! Er verschlingt das Fleisch und kaut kurz auf deinem Stiefel.")
    elif wahl == "2":
        if random.random() > 0.3:
            laune = min(100, laune + 30)
            print("\n❤️ Er genießt es und schnurrt wie ein kaputter Rasenmäher.")
        else:
            laune = max(0, laune - 20)
            print("\n💥 AUTSCH! Er hat versucht, deine Hand abzubeißen!")
    elif wahl == "3":
        laune = max(0, laune - 40)
        hunger = min(100, hunger + 10)
        print("\n😡 Der Squig schnappt wild nach dir und kackt demonstrativ ins Terminal!")
        
    speichere_squig(hunger, laune)
    print("\nZustand gespeichert. Schau später wieder nach ihm!\n")

if __name__ == "__main__":
    squig_pet()
