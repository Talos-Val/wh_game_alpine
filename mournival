def _tty() -> bool:
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()

class Col:
    RED    = "\033[91m"
    YELLOW = "\033[93m"
    GREEN  = "\033[92m"
    CYAN   = "\033[96m"
    MAGENTA= "\033[95m"
    BLUE   = "\033[94m"
    BOLD   = "\033[1m"
    DIM    = "\033[2m"
    RESET  = "\033[0m"

def c(code: str, text: str) -> str:
    return f"{code}{text}{Col.RESET}" if _tty() else text

# ═══════════════════════════════════════════════════════
#  Datenstrukturen
# ═══════════════════════════════════════════════════════

class Role(Enum):
    DOUBTER   = ("🗡", "Der Zweifler",   Col.YELLOW)   # Annahmen
    PESSIMIST = ("🛡", "Der Pessimist",  Col.RED)      # Fehlende Absicherung
    LOGICIAN  = ("⚖", "Der Logiker",    Col.CYAN)     # Widersprüche / Lücken
    FOOL      = ("🃏", "Der Narr",       Col.MAGENTA)  # Übersehenes Offensichtliches

    def __init__(self, icon: str, label: str, color: str):
        self.icon  = icon
        self.label = label
        self.color = color

@dataclass
class Finding:
    role:    Role
    title:   str
    detail:  str
    excerpt: str = ""   # relevanter Textteil

@dataclass
class AnalysisResult:
    findings: list[Finding] = field(default_factory=list)

    def add(self, role: Role, title: str, detail: str, excerpt: str = ""):
        self.findings.append(Finding(role, title, detail, excerpt))

    def by_role(self, role: Role) -> list[Finding]:
        return [f for f in self.findings if f.role == role]

# ═══════════════════════════════════════════════════════
#  Hilfs-Funktionen
# ═══════════════════════════════════════════════════════

def sentences(text: str) -> list[str]:
    parts = re.split(r'(?<=[.!?])\s+|\n{2,}', text.strip())
    return [p.strip() for p in parts if len(p.strip()) > 8]

def words(text: str) -> list[str]:
    return re.findall(r'\b\w+\b', text.lower())

def wordset(text: str) -> set[str]:
    return set(words(text))

def find_matches(pattern: str, text: str, flags=re.IGNORECASE) -> list[str]:
    hits = re.findall(pattern, text, flags)
    # Flatten tuples from groups into plain strings
    return [h[0] if isinstance(h, tuple) else h for h in hits]

def first_sentence_with(text: str, pattern: str) -> str:
    for s in sentences(text):
        if re.search(pattern, s, re.IGNORECASE):
            return s[:120]
    return ""

def count_matches(patterns: list[str], text: str) -> int:
    """Zählt alle Treffer über mehrere Muster."""
    return sum(len(find_matches(p, text)) for p in patterns)

def any_match(patterns: list[str], text: str) -> bool:
    return any(find_matches(p, text) for p in patterns)

def context_window(text: str, pattern: str, radius: int = 60) -> str:
    """Gibt den Text um einen Treffer herum zurück (für smartere Erklärungen)."""
    m = re.search(pattern, text, re.IGNORECASE)
    if not m:
        return ""
    start = max(0, m.start() - radius)
    end   = min(len(text), m.end() + radius)
    snippet = text[start:end].strip()
    return ("…" if start > 0 else "") + snippet + ("…" if end < len(text) else "")

def word_count(text: str) -> int:
    return len(re.findall(r'\b\w+\b', text))

def dedupe_findings(result: AnalysisResult):
    """Entfernt Duplikate mit gleichem Titel in derselben Rolle."""
    seen = set()
    unique = []
    for f in result.findings:
        key = (f.role, f.title)
        if key not in seen:
            seen.add(key)
            unique.append(f)
    result.findings = unique

