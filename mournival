def check_doubter(text: str, result: AnalysisResult):
    sents = sentences(text)
    wc = word_count(text)

    # ── Ungesicherte Annahmen ──────────────────────────────
    assumption_hits = []
    assumption_excerpt = ""
    for pattern in ASSUMPTION_HEDGES:
        hits = find_matches(pattern, text)
        if hits:
            assumption_hits.extend(hits)
            if not assumption_excerpt:
                assumption_excerpt = first_sentence_with(text, pattern)

    if assumption_hits:
        count = len(assumption_hits)
        examples = ", ".join(f"'{h}'" for h in assumption_hits[:3])
        if count == 1:
            detail = (
                f"Das Wort {examples} signalisiert eine Annahme, die nicht belegt ist. "
                f"Annahmen sind der häufigste Grund warum Pläne scheitern — nicht wegen "
                f"schlechter Ausführung, sondern weil die Grundlage nicht stimmte. "
                f"Stell dir vor, diese Annahme ist falsch: Was passiert dann mit dem Plan?"
            )
        else:
            detail = (
                f"Der Plan enthält {count} ungeprüfte Annahmen: {examples}. "
                f"Jede davon ist eine stille Wette. Wenn auch nur eine davon nicht stimmt, "
                f"kann das die gesamte Kette dahinter zum Einsturz bringen. "
                f"Welche dieser Annahmen wurde tatsächlich überprüft?"
            )
        result.add(Role.DOUBTER, "Ungeprüfte Annahmen", detail, assumption_excerpt)

    # ── Passiv ohne Verantwortlichen ──────────────────────
    passive_hits = []
    for pattern in PASSIVE_NO_ACTOR:
        passive_hits += find_matches(pattern, text)
    if passive_hits:
        examples = ", ".join(f"'{h}'" for h in passive_hits[:2])
        detail = (
            f"Formulierungen wie {examples} klingen wie ein Plan, "
            f"sind es aber nicht — sie beschreiben einen Wunsch ohne Träger. "
            f"In der Praxis bedeutet 'wird erledigt' meistens: niemand fühlt sich zuständig. "
            f"Wer genau übernimmt die Verantwortung, und bis wann?"
        )
        result.add(
            Role.DOUBTER, "Verantwortlichkeit unklar", detail,
            first_sentence_with(text, passive_hits[0])
        )

    # ── Externe Abhängigkeiten ────────────────────────────
    ext_hits = []
    for pattern in EXTERNAL_DEPENDENCY:
        ext_hits += find_matches(pattern, text)
    if ext_hits:
        count = len(ext_hits)
        examples = ", ".join(f"'{h}'" for h in ext_hits[:2])
        detail = (
            f"{'Eine externe Abhängigkeit' if count == 1 else f'{count} externe Abhängigkeiten'} "
            f"({examples}) ohne erkennbare Absicherung. "
            f"Externe Faktoren — Partner, Behörden, Lieferanten — sind die "
            f"unzuverlässigsten Teile jedes Plans, weil man sie nicht kontrolliert. "
            f"Was ist der Plan, wenn diese Abhängigkeit wegfällt, sich verzögert oder teurer wird?"
        )
        result.add(
            Role.DOUBTER, "Externe Abhängigkeit ohne Absicherung", detail,
            first_sentence_with(text, ext_hits[0])
        )

    # ── Nicht belegbare Marktannahmen ─────────────────────
    market_hits = []
    for pattern in MARKET_ASSUMPTIONS:
        market_hits += find_matches(pattern, text)
    if market_hits:
        detail = (
            f"Der Plan geht davon aus, dass ein Markt oder eine Nachfrage existiert "
            f"('{market_hits[0]}'). Das ist eine der gefährlichsten Annahmen überhaupt — "
            f"die meisten gescheiterten Projekte hatten ein gutes Produkt für eine Nachfrage, "
            f"die nie existierte. Welche Evidenz stützt diese Marktannahme konkret?"
        )
        result.add(
            Role.DOUBTER, "Ungeprüfte Marktannahme", detail,
            first_sentence_with(text, market_hits[0])
        )

    # ── Kompetenz-Annahmen ────────────────────────────────
    comp_hits = []
    for pattern in COMPETENCE_ASSUMPTIONS:
        comp_hits += find_matches(pattern, text)
    if comp_hits:
        detail = (
            f"Der Plan nimmt an, dass die nötige Kompetenz vorhanden ist "
            f"('{comp_hits[0]}'). Was genau ist diese Kompetenz, und wurde sie bereits "
            f"in vergleichbaren Situationen bewiesen — oder ist das ebenfalls eine Annahme?"
        )
        result.add(
            Role.DOUBTER, "Kompetenz-Annahme", detail,
            first_sentence_with(text, comp_hits[0])
        )

    # ── Ziel ohne Messbarkeit ─────────────────────────────
    goal_patterns = [
        r'\b(ziel|ziele|angestrebtes ergebnis|wir wollen|wir möchten|soll erreichen|angestrebt)\b',
        r'\b(vorhaben|absicht|intention|plan ist|ziel ist es)\b',
        r'\b(goal|objective|we want|we aim|we plan to|target|intention|desired outcome)\b',
    ]
    measure_patterns = [
        r'\b(\d+\s*%|\d+\s*(stück|einheiten|mal|tage|wochen|monate|euro|dollar|nutzer|kunden))\b',
        r'\b(bis (januar|februar|märz|april|mai|juni|juli|august|september|oktober|november|dezember))\b',
        r'\b(bis (q1|q2|q3|q4)|\d{4}|deadline|frist)\b',
        r'\b(by (january|february|march|april|may|june|july|august|september|october|november|december))\b',
        r'\b(by q[1-4]|\d{4}|until|no later than)\b',
        r'\b(kpi|kennzahl|messgröße|metric|benchmark|okr|target value)\b',
    ]
    has_goal    = any_match(goal_patterns, text)
    has_measure = any_match(measure_patterns, text)
    if has_goal and not has_measure:
        detail = (
            "Es gibt ein Ziel, aber keine messbaren Kriterien — keine Zahlen, "
            "keine Deadlines, keine KPIs. Das ist kein Zufall: Unmessbare Ziele "
            "können nie scheitern, weshalb sie auch nie erreicht werden. "
            "Was ist das konkrete, überprüfbare Ergebnis in 3 Monaten?"
        )
        result.add(Role.DOUBTER, "Ziel nicht messbar", detail)

    # ── Nur eine Meinung als Validierung ─────────────────
    single_opinion = [
        r'\b(ich (glaube|denke|bin überzeugt)|meiner meinung|meiner ansicht)\b',
        r'\b(I (think|believe|am convinced|feel)|in my opinion|I am sure)\b',
    ]
    expert_validation = [
        r'\b(studie|forschung|daten|umfrage|test|pilot|feedback|validiert|belegt)\b',
        r'\b(study|research|data|survey|test|pilot|feedback|validated|proven|evidence)\b',
    ]
    if any_match(single_opinion, text) and not any_match(expert_validation, text):
        detail = (
            "Die einzige Validierung im Plan scheint eine persönliche Überzeugung zu sein. "
            "Subjektive Gewissheit ist kein Ersatz für externe Evidenz. "
            "Was sagen Menschen außerhalb des Plans — Kunden, Experten, Daten?"
        )
        result.add(Role.DOUBTER, "Fehlende externe Validierung", detail)


