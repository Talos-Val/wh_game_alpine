def _opening_statement(role: Role, findings: list[Finding]) -> str:
    """Eröffnungsstatement einer Rolle, basierend auf ihren eigenen Findings."""
    titles = [f.title for f in findings[:2]]
    joined = " und ".join(f'„{t}"' for t in titles)
    intros = {
        Role.DOUBTER:   f"Ich stelle zunächst die Annahmen in Frage. Meine Kernpunkte: {joined}.",
        Role.PESSIMIST: f"Ich schaue auf die Absicherung. Was mich besorgt: {joined}.",
        Role.LOGICIAN:  f"Ich prüfe die innere Logik. Meine Beobachtungen: {joined}.",
        Role.FOOL:      f"Ich frage das Offensichtliche. Was hier fehlt: {joined}.",
    }
    return intros[role]

def print_discussion(result: AnalysisResult):
    """Druckt eine strukturierte Diskussion zwischen den Rollen."""
    active_roles = [r for r in Role if result.by_role(r)]

    if not active_roles:
        print(c(Col.GREEN, "\n  ✓ Keine Schwachstellen — kein Diskussionsbedarf.\n"))
        return

    print(c(Col.CYAN + Col.BOLD,
        "\n╔════════════════════════════════════════════╗"
        "\n║     D I S K U S S I O N S R U N D E       ║"
        "\n╚════════════════════════════════════════════╝\n"))

    # Runde 1: Eröffnungsstatements
    print(c(Col.BOLD, "  ── Runde 1: Eröffnungsstatements ─────────────────\n"))
    for role in active_roles:
        findings = result.by_role(role)
        stmt = _opening_statement(role, findings)
        header = c(role.color + Col.BOLD, f"  {role.icon}  {role.label}:")
        print(header)
        print(wrap(stmt))
        print()

    # Runde 2: Reaktionen untereinander
    print(c(Col.BOLD, "  ── Runde 2: Reaktionen ────────────────────────────\n"))
    for speaker in active_roles:
        for listener in active_roles:
            if speaker is listener:
                continue
            key = (speaker, listener)
            if key in _REACTIONS:
                reaction = _REACTIONS[key][0]
                header = c(speaker.color + Col.BOLD,
                           f"  {speaker.icon}  {speaker.label}")
                sub    = c(Col.DIM, f" → an {listener.icon} {listener.label}:")
                print(header + sub)
                print(wrap(reaction))
                print()

    # Runde 3: Gemeinsames Fazit
    print(c(Col.BOLD, "  ── Runde 3: Gemeinsames Fazit ─────────────────────\n"))
    count = len(result.findings)
    role_parts = "  ".join(
        c(r.color, f"{r.icon} {len(result.by_role(r))}")
        for r in active_roles
    )
    top_titles = ", ".join(f.title for f in result.findings[:3])
    print(wrap(
        f"Der Rat ist sich einig: Mit {count} identifizierten Schwachstellen "
        f"({', '.join(r.label for r in active_roles)}) sollte der Plan überarbeitet werden, "
        f"bevor er in die Umsetzung geht. Die drängendsten Punkte: {top_titles}."
    ))
    print()
    print(c(Col.DIM, "  Einzelbefunde: ") + role_parts + "\n")
    print(c(Col.DIM,
        "  Tipp: Ohne --dis siehst du die vollständigen Einzelbefunde.\n"))


