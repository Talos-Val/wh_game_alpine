def ensure_packages_and_import():
    required_packages = {"yt_dlp": "yt-dlp", "requests": "requests"}
    missing = []
    for module_name, pip_name in required_packages.items():
        try:
            __import__(module_name)
        except ImportError:
            missing.append(pip_name)
            
    if missing:
        print(f"{Y}[LITURGIE] Benötige zusätzliche Maschinengeist-Komponenten...{W}")
        try:
            if SYSTEM_OS == "linux":
                # Auf Linux: --break-system-packages für moderne Distros (PEP 668)
                try:
                    subprocess.check_call([sys.executable, "-m", "pip", "install", "--user",
                                           "--break-system-packages"] + missing)
                except subprocess.CalledProcessError:
                    # Fallback ohne --break-system-packages (ältere Distros)
                    subprocess.check_call([sys.executable, "-m", "pip", "install", "--user"] + missing)
            elif SYSTEM_OS == "windows":
                subprocess.check_call([sys.executable, "-m", "pip", "install", "--user"] + missing)
            elif SYSTEM_OS == "macos":
                subprocess.check_call([sys.executable, "-m", "pip", "install", "--user"] + missing)
            else:
                subprocess.check_call([sys.executable, "-m", "pip", "install", "--user"] + missing)
                
            user_site = os.path.expanduser("~/.local/lib/python" + ".".join(sys.version.split(".")[:2]) + "/site-packages")
            if user_site not in sys.path:
                sys.path.insert(0, user_site)
            print(f"{G}[STATUS] Komponenten erfolgreich gesalbt.{W}\n")
        except Exception as e:
            print(f"{R}[KATASTROPHE] Autarke Installation fehlgeschlagen: {e}{W}")
            if SYSTEM_OS == "linux" and SYSTEM_DISTRO:
                pm = get_package_manager_info(SYSTEM_DISTRO)
                print(f"{Y}[HINWEIS] Versuche manuell: {pm['install']} {pm['pkg_python']}{W}")
            sys.exit(1)

    from yt_dlp import YoutubeDL
    import requests
    return YoutubeDL, requests

def _find_executable(name):
    """Findet eine ausführbare Datei plattformübergreifend."""
    if SYSTEM_OS == "windows":
        # Windows: where-Befehl
        result = subprocess.call(["where", name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        # Linux / macOS: which-Befehl
        result = subprocess.call(["which", name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return result == 0

def check_ffmpeg():
    if not _find_executable("ffmpeg"):
        print(f"{Y}[WARNUNG] 'ffmpeg' fehlt! Ohne ffmpeg ist keine MP3-Operation möglich!{W}")
        if SYSTEM_OS == "linux" and SYSTEM_DISTRO:
            pm = get_package_manager_info(SYSTEM_DISTRO)
            print(f"{Y}[HINWEIS] Installiere mit: {pm['install']} {pm['pkg_ffmpeg']}{W}")
        elif SYSTEM_OS == "macos":
            print(f"{Y}[HINWEIS] Installiere mit: brew install ffmpeg{W}")
        elif SYSTEM_OS == "windows":
            print(f"{Y}[HINWEIS] Download: https://ffmpeg.org/download.html (zu PATH hinzufügen!){W}")
        return False
    return True

def clear_screen():
    """Bildschirm plattformübergreifend löschen."""
    if SYSTEM_OS == "windows":
        os.system("cls")
    else:
        os.system("clear")

