             or "youtube.com/shorts/" in user_input)
    if is_yt:
        print(f"\n{Y}[LOG] YouTube-Link erkannt. Extrahiere Audio direkt...{W}")
        artist_input = input(f"{C}» Künstler (für Ordnernamen, ENTER = Unbekannt): {W}").strip()
        artist_folder = get_safe_filename(artist_input) if artist_input else "Unbekannter_Saenger"
        target_dir = f"{vault_dir}/Music_Schrein/Kuenstler/{artist_folder}"
        os.makedirs(target_dir, exist_ok=True)
        ydl_opts_yt = {
            'format': 'bestaudio/best',
            'outtmpl': f'{target_dir}/%(title)s.%(ext)s',
            'quiet': False,
            'http_headers': BROWN_GEAR_HEADERS,
            'user_agent': BROWN_GEAR_HEADERS['User-Agent'],
        }
        if ffmpeg_available:
            ydl_opts_yt['postprocessors'] = [{
                'key': 'FFmpegExtractAudio',
                'preferredcodec': 'mp3',
                'preferredquality': '320',
            }]
        try:
