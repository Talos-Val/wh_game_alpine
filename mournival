def check_logician(text: str, result: AnalysisResult):
    sents = sentences(text)

    # ── Widerspruchspaare ─────────────────────────────────
    for pat_a, pat_b, desc in CONTRADICTION_PAIRS:
        hits_a = find_matches(pat_a, text)
        hits_b = find_matches(pat_b, text)
        if hits_a and hits_b:
            detail = (
                f"'{hits_a[0]}' und '{hits_b[0]}' stehen im Konflikt: {desc}"
            )
            result.add(Role.LOGICIAN, "Interner Widerspruch", detail,
                       first_sentence_with(text, pat_a))

    # ── Kausallücken ──────────────────────────────────────
    consequence_pat = re.compile(
        r'\b(dann|deshalb|daher|folglich|deswegen|therefore|thus|hence|so|consequently|as a result)\b',
        re.IGNORECASE
    )
    reason_pat = re.compile(
        r'\b(weil|da|denn|durch|mittels|indem|because|since|by|through|via|by means of)\b',
        re.IGNORECASE
    )
    causal_sents = [s for s in sents if consequence_pat.search(s)]
    has_reason   = any(reason_pat.search(s) for s in sents)
    if causal_sents and not has_reason:
        detail = (
            f"Der Plan zieht Schlussfolgerungen — '{causal_sents[0][:60]}…' — "
            f"ohne zu erklären durch welchen Mechanismus das eintritt. "
            f"'Dann' ist kein Argument, es ist eine Hoffnung. "
            f"Was genau bewirkt den Übergang von A nach B?"
        )
        result.add(Role.LOGICIAN, "Kausallücke", detail,
                   causal_sents[0][:100] if causal_sents else "")

    # ── Zirkelschlüsse ────────────────────────────────────
    for pat_a, pat_b, desc in CIRCULAR_INDICATORS:
        if find_matches(pat_a, text) and find_matches(pat_b, text):
            result.add(Role.LOGICIAN, "Möglicher Zirkelschluss", desc)

    # ── Scope Creep ───────────────────────────────────────
    scope_hits = count_matches(SCOPE_CREEP_PATTERNS, text)
    if scope_hits >= 2:
        detail = (
            f"Der Plan häuft Ziele auf ({scope_hits} additive Erweiterungen). "
            f"Scope Creep ist keine böse Absicht — er entsteht dadurch, "
            f"dass gute Ideen nicht priorisiert werden. "
            f"Was ist das eine Kernziel? Alles andere ist Ablenkung bis das erreicht ist."
        )
        result.add(Role.LOGICIAN, "Scope Creep", detail)

    # ── Fehlender Mechanismus ─────────────────────────────
    for pat_a, pat_b, desc in MISSING_MECHANISM:
        if find_matches(pat_a, text) and not find_matches(pat_b, text):
            result.add(Role.LOGICIAN, "Fehlender Mechanismus", desc,
                       first_sentence_with(text, pat_a))
            break

    # ── Falsches Dilemma ──────────────────────────────────
    fd_hits = []
    for p in FALSE_DILEMMA_PATTERNS:
        fd_hits += find_matches(p, text)
    if fd_hits:
        detail = (
            f"Der Plan stellt eine Entweder-oder-Wahl auf ('{fd_hits[0]}'). "
            f"Echte Dilemmata sind selten — meistens gibt es einen dritten Weg, "
            f"der nicht betrachtet wurde. Welche Optionen wurden ausgeschlossen?"
        )
        result.add(Role.LOGICIAN, "Falsches Dilemma", detail,
                   first_sentence_with(text, fd_hits[0]))

    # ── Überlappende Verantwortlichkeiten ─────────────────
    overlap_pat = re.compile(
        r'\b(beide|alle|wir alle|gemeinsam|zusammen|everyone|all of us|jointly|collectively)\s+'
        r'.{0,20}\s*(verantwortlich|zuständig|responsible|in charge|accountable)\b',
        re.IGNORECASE
    )
    if overlap_pat.search(text):
        detail = (
            "Wenn alle verantwortlich sind, ist niemand verantwortlich. "
            "Geteilte Verantwortung ohne klare Rollenverteilung führt dazu, "
            "dass jeder davon ausgeht, jemand anderes kümmert sich. "
            "Wer hat das letzte Wort — eine Person, eine Stimme?"
        )
        result.add(Role.LOGICIAN, "Diffuse Verantwortung", detail)

    # ── Zeitliche Inkonsistenz ────────────────────────────
    past_tense  = re.compile(r'\b(haben|hatte|war|wurde|has|had|was|were|did)\b', re.IGNORECASE)
    future_tense = re.compile(r'\b(wird|werden|soll|wollen|will|shall|going to)\b', re.IGNORECASE)
    present_tense = re.compile(r'\b(ist|sind|machen|tun|is|are|do|does|currently)\b', re.IGNORECASE)
    tenses = sum([
        bool(past_tense.search(text)),
        bool(future_tense.search(text)),
        bool(present_tense.search(text))
    ])
    if tenses == 3 and len(sents) > 3:
        # Nur melden wenn mehrere Zeiten durcheinander im gleichen Plan
        past_sents   = [s for s in sents if past_tense.search(s)]
        future_sents = [s for s in sents if future_tense.search(s)]
        if past_sents and future_sents:
            detail = (
                "Der Plan wechselt zwischen Vergangenheits-, Gegenwarts- und Zukunftsform. "
                "Das kann auf unklare Zeitlinien hinweisen: Was ist bereits passiert, "
                "was ist geplant, und was passiert gerade? Eine klare Zeitstruktur "
                "macht den Plan deutlich greifbarer."
            )
            result.add(Role.LOGICIAN, "Zeitliche Unklarheit", detail)


