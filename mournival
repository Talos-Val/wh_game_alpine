    r'\b(best case|im besten fall|wenn alles klappt|wenn alles läuft)\b',
    r'\b(optimistic(ally)?|rosige aussichten|alles wird gut|wird schon klappen)\b',
    r'\b(best.case scenario|if everything goes well|assuming all goes to plan)\b',
]

def check_pessimist(text: str, result: AnalysisResult):
    sents = sentences(text)

    # ── Kein Fallback-Plan ────────────────────────────────
    has_fallback = any_match(FALLBACK_INDICATORS, text)
    if not has_fallback:
        detail = (
            "Kein Plan B erkennbar. Das ist kein Pessimismus — das ist Mathematik: "
            "Je mehr Schritte ein Plan hat, desto unwahrscheinlicher ist es, "
            "dass alle reibungslos funktionieren. Was ist der Mindest-Fallback "
            "für den wahrscheinlichsten Fehlerfall?"
        )
        result.add(Role.PESSIMIST, "Kein Fallback-Plan", detail)

    # ── Fehlende Planungsdimensionen ──────────────────────
    has_resource  = any_match(RESOURCE_WORDS, text)
    has_time      = any_match(TIME_WORDS, text)
    has_personnel = any_match(PERSONNEL_WORDS, text)
    has_risk      = any_match(RISK_WORDS, text)

    missing = []
    if not has_resource:  missing.append("Budget / Ressourcen")
    if not has_time:      missing.append("Zeitplan / Meilensteine")
    if not has_personnel: missing.append("Verantwortliche Personen / Rollen")

    if missing:
        dimension_map = {
            "Budget / Ressourcen":           "Ohne Ressourcenplanung ist jeder Plan ein Wunsch.",
            "Zeitplan / Meilensteine":        "Ohne Zeitplan gibt es keinen Fortschritt, nur Aktivität.",
            "Verantwortliche Personen / Rollen": "Ohne Rollen macht jeder alles — und niemand irgendetwas.",
        }
        reasons = " / ".join(dimension_map[m] for m in missing)
        detail = (
            f"Fehlende Dimensionen: {', '.join(missing)}. "
            f"{reasons} "
            f"Ein Plan der diese Fragen nicht beantwortet, ist kein Plan — "
            f"es ist eine Idee."
        )
        result.add(Role.PESSIMIST, "Planungslücken", detail)

    # ── Keine Risikobetrachtung ───────────────────────────
    if not has_risk:
        detail = (
            "Keine Risiken erwähnt. Das bedeutet entweder, dass keine existieren "
            "(unwahrscheinlich), oder dass sie nicht betrachtet wurden (gefährlich). "
            "Was sind die drei größten Dinge, die diesen Plan zum Scheitern bringen könnten? "
            "Diese drei Antworten gehören in den Plan."
        )
        result.add(Role.PESSIMIST, "Keine Risikoanalyse", detail)

    # ── Single Point of Failure ───────────────────────────
    for pattern in SINGLE_POINT_PATTERNS:
        hits = find_matches(pattern, text)
        if hits:
            detail = (
                f"'{hits[0]}' deutet auf einen Single Point of Failure hin — "
                f"alles hängt an einer Person, einem System oder einer Entscheidung. "
                f"Das ist kein Plan, das ist eine Lotterie. Was passiert konkret, "
                f"wenn genau dieser Punkt wegfällt?"
            )
            result.add(Role.PESSIMIST, "Single Point of Failure", detail,
                       first_sentence_with(text, pattern))
            break

    # ── Irreversible Schritte ohne Sicherheitsnetz ────────
    irrev_hits = []
    for p in IRREVERSIBLE_PATTERNS:
        irrev_hits += find_matches(p, text)
    if irrev_hits:
        detail = (
            f"Der Plan enthält irreversible Schritte ('{irrev_hits[0]}'). "
            f"Maßnahmen, die nicht rückgängig zu machen sind, brauchen zwingend "
            f"einen expliziten Bestätigungsschritt, eine Sicherungskopie oder "
            f"eine Möglichkeit zur Wiederherstellung. Wurde das eingeplant?"
        )
        result.add(Role.PESSIMIST, "Irreversibler Schritt ohne Sicherung", detail,
                   first_sentence_with(text, irrev_hits[0]))

    # ── Reiner Optimismus-Bias ────────────────────────────
    opt_hits = []
    for p in OPTIMISM_BIAS:
        opt_hits += find_matches(p, text)
    if opt_hits and not has_risk:
        detail = (
            f"Der Plan denkt im Best-Case ('{opt_hits[0]}'), aber enthält keine "
            f"Worst-Case-Überlegung. Pläne sollten auf dem wahrscheinlichsten Fall "
            f"basieren, nicht auf dem besten. Was ist der realistische Fall, "
            f"nicht der optimistische?"
        )
        result.add(Role.PESSIMIST, "Optimismus-Bias", detail,
                   first_sentence_with(text, opt_hits[0]))

    # ── Skalierungs-Risiko ────────────────────────────────
    scale_trigger = [
        r'\b(skalier|wachsen|expandieren|ausrollen|ausweiten|scale|grow|expand|roll out)\b',
    ]
    scale_concern = [
        r'\b(infrastruktur|kapazität|server|personal|kosten|infrastructure|capacity|staff|cost)\b',
    ]
    if any_match(scale_trigger, text) and not any_match(scale_concern, text):
        detail = (
            "Wachstum oder Skalierung ist geplant, aber die dafür nötige Infrastruktur, "
            "Kapazität oder der Personalaufbau werden nicht adressiert. "
            "Was skaliert mit? Was wird zum Flaschenhals, wenn das Volumen steigt?"
        )
        result.add(Role.PESSIMIST, "Skalierungs-Risiko nicht adressiert", detail)


