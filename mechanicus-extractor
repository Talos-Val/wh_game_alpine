def synthesize_playlist():
    if not check_ffmpeg(): return
    vault_dir = load_vault_dir()
    music_dir = f"{vault_dir}/Music_Schrein"
    playlist_dir = f"{vault_dir}/Music_Schrein/Playlists"

    print(f"\n{B}{R}[RITUS IV] PLAYLIST-SCHMIEDE (INTERAKTIVE AUSWAHL){W}")

    if not os.path.exists(music_dir):
        print(f"{Y}[LOG] Der Musik-Schrein existiert noch nicht.{W}")
        return

    # Alle MP3s finden und sortiert nummerieren
    all_tracks = []
    for root, dirs, files in os.walk(music_dir):
        for file in sorted(files):
            if file.endswith(".mp3"):
                abs_path = os.path.join(root, file)
                rel_path = os.path.relpath(abs_path, music_dir)
                all_tracks.append((rel_path, abs_path))
    all_tracks.sort(key=lambda x: x[0])

    if not all_tracks:
        print(f"{Y}[LOG] Keine .mp3-Dateien im Schrein gefunden.{W}")
        return

    # Alle Tracks nummeriert anzeigen
    print(f"\n{C}{'─'*60}{W}")
    print(f"{B}  ARCHIV-BIBLIOTHEK ({len(all_tracks)} Tracks){W}")
    print(f"{C}{'─'*60}{W}")
    for idx, (rel_path, _) in enumerate(all_tracks, 1):
        # rel_path = "Kuenstler/Songname.mp3" → lesbar aufbereiten
        parts = rel_path.replace("\\", "/").split("/")
        if len(parts) == 2:
            artist_display = parts[0]
            title_display = parts[1].replace(".mp3", "")
            print(f"  [{Y}{idx:>3}{W}] {B}{title_display}{W}  {C}({artist_display}){W}")
        else:
            print(f"  [{Y}{idx:>3}{W}] {rel_path.replace('.mp3','')}")
    print(f"{C}{'─'*60}{W}")

    # Playlist-Name zuerst
    playlist_name = input(f"\n{C}» Name der Playlist (ENTER = Auto-Name): {W}").strip()
    if not playlist_name:
        playlist_name = f"Chronik_Mix_{datetime.now().strftime('%Y%m%d_%H%M')}"
    playlist_name = get_safe_filename(playlist_name) + ".mp3"

    # Nummern eingeben
    print(f"\n{Y}Gib die Track-Nummern in der gewünschten Reihenfolge ein.")
    print(f"Beispiel: {B}4, 7, 9, 1, 12{W}  oder  {B}4 7 9 1 12{W}")
    print(f"Doppelte Nummern = Track mehrfach in Playlist.{W}")
    raw = input(f"\n{B}{R}» Auswahl » {W}").strip()
    if not raw:
        print(f"{Y}[LOG] Keine Auswahl. Abbruch.{W}")
        return

    # Nummern parsen (Komma oder Leerzeichen als Trenner)
    raw_tokens = re.split(r'[\s,]+', raw)
    selected_paths = []
    errors = []
    for token in raw_tokens:
        if not token: continue
        if not token.isdigit():
            errors.append(f"'{token}' ist keine Zahl")
            continue
        num = int(token)
        if 1 <= num <= len(all_tracks):
            selected_paths.append(all_tracks[num - 1])
        else:
            errors.append(f"{num} außerhalb des Bereichs (1–{len(all_tracks)})")

    if errors:
        for e in errors:
            print(f"{Y}[WARNUNG] {e}{W}")

    if not selected_paths:
        print(f"{R}[ABBRUCH] Keine gültigen Tracks ausgewählt.{W}")
        return

    # Auswahl bestätigen
    print(f"\n{C}{'─'*60}{W}")
    print(f"{B}  PLAYLIST: {playlist_name}{W}")
    print(f"{C}{'─'*60}{W}")
    for i, (rel_path, _) in enumerate(selected_paths, 1):
        parts = rel_path.replace("\\", "/").split("/")
        if len(parts) == 2:
            print(f"  {i:>2}. {B}{parts[1].replace('.mp3','')}{W}  {C}({parts[0]}){W}")
        else:
            print(f"  {i:>2}. {rel_path.replace('.mp3','')}")
    print(f"{C}{'─'*60}{W}")
    confirm = input(f"\n{Y}» Playlist so schmieden? (y/ENTER zum Abbrechen): {W}").strip().lower()
    if confirm != 'y':
        print(f"{Y}[LOG] Abgebrochen.{W}")
        return

    # ffmpeg concat
    os.makedirs(playlist_dir, exist_ok=True)
    output_path = os.path.join(playlist_dir, playlist_name)
    list_txt_path = os.path.join(music_dir, "temp_playlist_forge.txt")

    try:
        with open(list_txt_path, "w", encoding="utf-8") as f:
            for _, abs_path in selected_paths:
                safe_abs_path = abs_path.replace("'", "\\'")
                f.write(f"file '{safe_abs_path}'\n")

        print(f"\n{Y}[LOG] ffmpeg fügt Tracks nahtlos zusammen...{W}")
        cmd = ["ffmpeg", "-y", "-f", "concat", "-safe", "0",
               "-i", list_txt_path, "-c", "copy", output_path]
        process = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
        if process.returncode == 0:
            print(f"\n{G}✓ [ERFOLG] Playlist geschmiedet!{W}")
            print(f"{C}[PFAD] {output_path}{W}")
        else:
            print(f"\n{R}[FEHLER] {process.stderr.decode()}{W}")
    finally:
        if os.path.exists(list_txt_path): os.remove(list_txt_path)

def get_safe_filename(text):
    return "".join([c for c in text if c.isalnum() or c in " _-"]).strip()

