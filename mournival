def wrap(text: str, indent: int = 6) -> str:
    pad = " " * indent
    return textwrap.fill(text, width=WRAP_WIDTH,
                         initial_indent=pad,
                         subsequent_indent=pad)

def print_findings(result: AnalysisResult):
    if not result.findings:
        print(c(Col.GREEN, "\n  ✓ Keine Schwachstellen gefunden. Der Plan wirkt solide.\n"))
        return

    total = len(result.findings)
    print(c(Col.BOLD, f"\n  ═══ {total} Schwachstelle(n) gefunden ═══\n"))

    for role in Role:
        findings = result.by_role(role)
        if not findings:
            continue

        header = c(role.color + Col.BOLD,
                   f"  {role.icon}  {role.label}  ({len(findings)})")
        print(header)
        print(c(Col.DIM, "  " + "─" * 50))

        for i, f in enumerate(findings, 1):
            print(c(Col.BOLD, f"\n  [{i}] {f.title}"))
            print(wrap(f.detail))
            if f.excerpt:
                excerpt = f.excerpt[:100].strip()
                print(c(Col.DIM, wrap(f'→ "{excerpt}…"' if len(f.excerpt) > 100
                                       else f'→ "{excerpt}"')))
        print()

def print_summary(result: AnalysisResult):
    if not result.findings:
        return
    counts = {role: len(result.by_role(role)) for role in Role}
    parts = [c(role.color, f"{role.icon} {n}") for role, n in counts.items() if n > 0]
    print(c(Col.DIM, "  Zusammenfassung: ") + "  ".join(parts) + "\n")


