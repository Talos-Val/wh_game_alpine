def main():
    parser = argparse.ArgumentParser(description="Grimdark Omnis-Tool - Linux Command Center for 40k Nerds.")
    parser.add_argument("--faction", type=str, default="custodes", choices=["custodes", "thousand_sons", "orks", "night_lords"], help="Initial faction theme.")
    parser.add_argument("--interactive", action="store_true", help="Launch interactive visual shell menu.")
    parser.add_argument("--telemetry", action="store_true", help="Inspect cogitator resources.")
    parser.add_argument("--backup", type=str, metavar="PATH", help="Backup a specific directories.")
    parser.add_argument("--clean", action="store_true", help="Purge system garbage and caches.")
    parser.add_argument("--scan", type=str, metavar="HOST", help="Audit network open ports.")
    parser.add_argument("--ports", type=str, default="22,80,443,8080", help="Comma separated list of ports for scanning.")
    
    args = parser.parse_args()
    
    if not any([args.interactive, args.telemetry, args.backup, args.clean, args.scan]):
        display_menu(args.faction)
        return

    # Non-interactive mode
    if args.telemetry:
        get_system_telemetry(args.faction)
    if args.backup:
        perform_backup(args.faction, args.backup)
    if args.clean:
        purge_archives(args.faction)
    if args.scan:
        scan_warp(args.faction, args.scan, args.ports)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nCogitator ritual abruptly interrupted. Entering Stasis.")
        sys.exit(0)
