    pm = "apt" if shutil.which("apt-get") else ("pacman" if shutil.which("pacman") else "dnf")
    commands = {
        "apt": ["sudo apt-get update -y", "sudo apt-get install -y git curl htop tmux build-essential python3-pip"],
        "pacman": ["sudo pacman -Syu --noconfirm", "sudo pacman -S --needed --noconfirm git curl htop tmux base-devel python-pip"],
        "dnf": ["sudo dnf check-update", "sudo dnf install -y git curl htop tmux gcc python3-pip"]
    }
    
    print(f"Detected Package Manager: {C_BOLD}{pm.upper()}{C_END}")
    for cmd in commands.get(pm, []):
        print(f"   {cmd}")

