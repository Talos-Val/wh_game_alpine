#!/usr/bin/env python3
import os
import sys
import urllib.request

# --- DEINE REPO-DATEN ---
GITHUB_USER = "Talos-Val"
REPO_NAME = "linux_tools"
# -----------------------

# Die Liste aller Tools und ihre Beschreibungen
TOOLS = {
    "binary-life": "Simulation: Nullen und Einsen kämpfen um die Shell.",
    "bork-filter": "Muppet-Chefkoch-Übersetzer.",
    "busy-worker": "Fake-Ladebalken zur Arbeits-Tarnung.",
    "casino-slot": "Einarmiger Bandit mit Emojis.",
    "cli-clicker": "Idle-Clicker-Spiel mit Auto-Coder-Bots.",
    "crazy-pass": "Generiert extrem sichere, absurde Passwörter.",
    "doom-fortune": "Düstere Zukunftsvorhersagen.",
    "ghaz-say": "Ghazghull beleidigt dich.",
    "ghost-type": "Tipp-Effekt mit absichtlichen Fehlern.",
    "my-squig": "Dein Terminal-Tamagotchi.",
    "rage-timer": "Passiv-aggressiver Countdown-Wecker.",
    "sound-reflex": "Reflex-Test via Piepton.",
    "spacemarine-quote": "Epischer Motivations-Banner.",
    "terminal-beep": "Wandelt Text in Morse-Code um.",
    "wh-alpine": "Das Warhammer-Hauptspiel."
    "worm-race": "Ein Wurmrennen."
}

INSTALL_DIR = "/usr/local/bin"

def zeige_uebersicht():
    print("\n" + "="*60)
    print("🤖  TERMINAL-TOOLS: STARTE MIT DEM TOOLNAMEN  🤖")
    print("="*60)
    for befehl, info in TOOLS.items():
        print(f"  \033[92m{befehl:<20}\033[0m -> {info}")
    print("="*60)
    print("Tippe den grünen Namen ein, um das Tool zu starten.")
    print("Nutze 'installer --install', um alle Tools zu aktualisieren.\n")

def installiere_tools():
    print(f"🌐 Lade Tools von github.com/{GITHUB_USER}/{REPO_NAME}...")
    
    # Sicherstellen, dass das Verzeichnis existiert
    if not os.path.exists(INSTALL_DIR):
        os.makedirs(INSTALL_DIR)
        
    for tool in TOOLS.keys():
        url = f"https://raw.githubusercontent.com/{GITHUB_USER}/{REPO_NAME}/main/{tool}"
        ziel_pfad = os.path.join(INSTALL_DIR, tool)
        
        try:
            urllib.request.urlretrieve(url, ziel_pfad)
            os.chmod(ziel_pfad, 0o755)
            print(f"✅ {tool} bereit.")
        except Exception as e:
            print(f"❌ Fehler bei {tool}: {e}")
            
    print("\n🔄 Alle Tools wurden aktualisiert und sind unter ihrem Namen startbereit.")

if __name__ == "__main__":
    # Wenn '--install' als Argument kommt, installiere. Sonst zeige nur die Liste.
    if len(sys.argv) > 1 and sys.argv[1] == "--install":
        installiere_tools()
    else:
        zeige_uebersicht()
