def check_fool(text: str, result: AnalysisResult):
    sents = sentences(text)
    wc = word_count(text)

    # ── Fehlende Basics ───────────────────────────────────
    for trigger, missing_pat, desc in FORGOTTEN_BASICS:
        has_trigger = bool(find_matches(trigger, text))
        has_answer  = bool(find_matches(missing_pat, text))
        if has_trigger and not has_answer:
            result.add(
                Role.FOOL, "Vergessenes Offensichtliches", desc,
                first_sentence_with(text, trigger)
            )

    # ── Vage Sprache ──────────────────────────────────────
    vague_hits = []
    for p in VAGUE_TERMS:
        vague_hits += find_matches(p, text)
    if len(vague_hits) >= 2:
        examples = ", ".join(f"'{h}'" for h in dict.fromkeys(vague_hits)[:4])
        detail = (
            f"Der Plan verwendet {len(vague_hits)} vage Formulierungen: {examples}. "
            f"Vagheit ist kein Stil — sie ist ein Zeichen dafür, dass etwas noch nicht "
            f"durchgedacht wurde. Was genau steckt hinter diesen Wörtern?"
        )
        result.add(Role.FOOL, "Zu vage Formulierungen", detail)

    # ── Buzzword-Dichte ───────────────────────────────────
    buzz_hits = []
    for p in BUZZWORD_PATTERNS:
        buzz_hits += find_matches(p, text)
    if len(buzz_hits) >= 3:
        examples = ", ".join(f"'{h}'" for h in dict.fromkeys(buzz_hits)[:4])
        detail = (
            f"Hohe Buzzword-Dichte: {examples}. "
            f"Buzzwords sind oft Platzhalter für Konzepte, die noch nicht konkret gedacht wurden. "
            f"Was bedeuten diese Begriffe im konkreten Kontext dieses Plans, "
            f"und wie genau werden sie umgesetzt?"
        )
        result.add(Role.FOOL, "Buzzword-Überladung", detail)

    # ── Zu wenig ausgearbeitet ────────────────────────────
    if wc < 50:
        detail = (
            f"Der Text hat nur {wc} Wörter — das ist ein Stichwort, kein Plan. "
            f"Ein Plan ist ausgearbeitet genug, wenn jemand der nicht dabei war "
            f"ihn lesen und selbstständig umsetzen könnte. "
            f"Was fehlt: Kontext, Schritte, Verantwortlichkeiten, Zeitplan?"
        )
        result.add(Role.FOOL, "Plan zu wenig ausgearbeitet", detail)

    # ── Keine Erfolgsdefinition ───────────────────────────
    success_patterns = [
        r'\b(erfolgreich|ziel erreicht|abgeschlossen|fertiggestellt|abgenommen)\b',
        r'\b(successful|completed|done|finished|achieved|delivered|signed off)\b',
        r'\b(definition of done|akzeptanzkriterien|acceptance criteria|done criteria)\b',
    ]
    if not any_match(success_patterns, text):
        detail = (
            "Der Plan definiert nicht, wann er abgeschlossen ist. "
            "Ohne Erfolgskriterium gibt es kein Ziel, keine Energie und kein Ende — "
            "der Plan läuft ewig weiter oder stirbt ohne Abschluss. "
            "Was ist der konkrete Zustand, bei dem alle sagen: 'Das ist geschafft'?"
        )
        result.add(Role.FOOL, "Kein Erfolgskriterium", detail)

    # ── Vergessene Grundfragen ────────────────────────────
    for trigger, missing_pat, desc in FORGOTTEN_QUESTIONS:
        if find_matches(trigger, text) and not find_matches(missing_pat, text):
            result.add(
                Role.FOOL, "Unbeantwortete Grundfrage", desc,
                first_sentence_with(text, trigger)
            )

    # ── Exit-Strategie ────────────────────────────────────
    long_term = [
        r'\b(langfristig|dauerhaft|für immer|permanent|long.term|permanently|forever|ongoing)\b',
    ]
    exit_pat = [
        r'\b(exit|ausstieg|beenden|abwickeln|end|wind down|sunset|discontinue|sell|verkaufen)\b',
    ]
    if any_match(long_term, text) and not any_match(exit_pat, text):
        detail = (
            "Der Plan ist auf Dauerhaftigkeit ausgelegt, aber enthält keine Exit-Überlegung. "
            "Was passiert, wenn das Projekt eingestellt werden muss, "
            "jemand aussteigt, oder die Umstände sich radikal ändern?"
        )
        result.add(Role.FOOL, "Keine Exit-Strategie", detail)


