def verarbeite_statuseffekte(char, effekte, ist_spieler):
    schaden_seite = "Du leidest" if ist_spieler else f"{char['name']} leidet"
    neue_effekte = []
    runden_schaden = 0
    
    for eff in effekte:
        if eff == "brennend":
            runden_schaden += 1
            print(f"🔥 {schaden_seite} unter 'Brennend'! (-1 LP durch Flammen)")
            neue_effekte.append(eff) # Hält permanent bis Spielende
        elif eff == "blutend":
            runden_schaden += 2
            print(f"🩸 {schaden_seite} unter 'Blutend'! (-2 LP durch Blutverlust)")
            # 50% Chance, dass die Wunde schließt
            if random.random() > 0.5:
                neue_effekte.append(eff)
            else:
                print("🩹 Die Blutung hat aufgehört.")
        elif eff == "niedergehalten":
            print(f"😨 {schaden_seite} unter 'Niedergehalten'! (Nächster Angriff geschwächt)")
            # Hält nur eine Runde, wird also nicht wieder angehängt
            
    char["lp"] -= runden_schaden
    return neue_effekte

def generiere_narrative(angreifer, verteidiger, skill, gewuerfelt, schaden, effekt):
    name_a = angreifer["name"]
    name_v = verteidiger["name"]
    s_name = skill["name"]
    
    if schaden == 0:
        return f"🛡️ {name_a} setzt {s_name} ein, aber {name_v} fängt den Schlag geschickt ab oder weicht aus!"

    text = f"⚔️ {name_a} nutzt **{s_name}**! "
    
    # Zustandsskalierung
    ratio_a = angreifer["lp"] / angreifer["max_lp"]
    if ratio_a < 0.3:
        text += "Obwohl der Angreifer dem Tod nah ist, bricht der Angriff verzweifelt hervor. "
    elif verteidiger["lp"] <= 3:
        text += f"Ein vernichtender Schlag gegen den bereits wankenden {name_v}! "

    # Schadenstyp-Flavour
    if skill["typ"] == "wuchtig":
        text += f"Die Wucht des Angriffs lässt den Boden erzittern und schmettert durch die feindliche Rüstung! (**-{schaden} LP**)"
    elif effekt:
        eff_texte = {"brennend": "🔥 Flammen breiten sich aus!", "blutend": "🩸 Tiefes Fleisch wird zerrissen!", "niedergehalten": "😨 Panik bricht aus!"}
        text += f"Der Treffer sitzt! {eff_texte.get(effekt, '')} (**-{schaden} LP**)"
    else:
        text += f"Ein sauberer Treffer schwächt das Ziel. (**-{schaden} LP**)"

    return text

def wuerfele_angriff(skill, angreifer_effekte, verteidiger_type):
    wuerfel = random.randint(1, 6)
    
    # Modifikatoren durch Statuseffekte oder Fraktionen
    ziel = 3
    if skill["typ"] == "wuchtig": ziel += 1
    if verteidiger_type == "nl" and random.random() > 0.7: ziel += 1 # NL Passiv-Ausweichen
    if "niedergehalten" in angreifer_effekte: ziel += 1 # Eigener Malus
        
    schaden = 0
    if wuerfel >= ziel:
        schaden = skill["schaden"]
        if wuerfel == 6: schaden += 1 # Kritischer Treffer
    return wuerfel, schaden

def empfange_daten():
    global conn, mein_zug, spiel_aktiv, gegner_char, aktive_effekte_spieler, aktive_effekte_gegner
    while spiel_aktiv:
        try:
            daten = conn.recv(1024).decode('utf-8')
            if not daten: break
            befehl, wert = daten.split(":", 1)
            
            if befehl == "HELLO":
                idx = wert.strip()
                gegner_char = SUBKLASSEN[idx].copy()
                print(f"\n🤝 Match steht! Dein Gegner: {gegner_char['name']}")
                print(f"ℹ️ Passiv des Gegners: {gegner_char['passiv']}")
                if mein_zug: zeige_kampf_interface()
            
            elif befehl == "ANGRIFF":
                skill_id, wuerfel, schaden, effekt = wert.split(",")
                wuerfel, schaden = int(wuerfel), int(schaden)
                skill = gegner_char["skills"][skill_id]
                
                narrativ = generiere_narrative(gegner_char, mein_char, skill, wuerfel, schaden, effekt if effekt != "None" else None)
                print(f"\n{narrativ}")
                
                mein_char["lp"] -= schaden
                if effekt != "None" and effekt not in aktive_effekte_spieler:
                    aktive_effekte_spieler.append(effekt)
                
                print(f"\n❤️ Deine LP: {max(0, mein_char['lp'])}/{mein_char['max_lp']} | Gegner LP: {gegner_char['lp']}/{gegner_char['max_lp']}")
                
                if mein_char["lp"] <= 0:
                    print("\n💀 DU BIST GEFALLEN... Die Schlacht ist verloren.")
                    conn.sendall("ENDE:VERLOREN".encode('utf-8'))
                    spiel_aktiv = False
                    break
                
                # Zugwechsel zu dir -> Deine Effekte triggern am Anfang deines Zuges
                aktive_effekte_spieler = verarbeite_statuseffekte(mein_char, aktive_effekte_spieler, True)
                mein_zug = True
                zeige_kampf_interface()
            
            elif befehl == "ENDE":
                print("\n🏆 SIEG! Du hast das Duell im Namen deiner Fraktion entschieden!")
                spiel_aktiv = False
                break
        except:
            break

def get_local_ip():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(('10.255.255.255', 1))
        ip = s.getsockname()[0]
    except:
        ip = '127.0.0.1'
    finally:
        s.close()
    return ip

def zeige_kampf_interface():
    print(f"\n--- DEIN ZUG --- (LP: {mein_char['lp']}/{mein_char['max_lp']} | Effekte: {aktive_effekte_spieler})")
    print("Wähle deine Attacke:")
    for k, v in mein_char["skills"].items():
        eff_info = f" [Effekt: {v['effekt']}]" if v['effekt'] else ""
        print(f"{k} - {v['name']} (Schaden: {v['schaden']}){eff_info} -> {v['desc']}")
    print("> ", end="")
    sys.stdout.flush()

def bot_turn():
    global mein_zug, spiel_aktiv, aktive_effekte_gegner, aktive_effekte_spieler
    print(f"\n🤖 {gegner_char['name']} bereitet seinen Angriff vor...")
    time.sleep(2.0)
    
    skill_id = random.choice(["1", "2", "3"])
    skill = gegner_char["skills"][skill_id]
    
    wuerfel, schaden = wuerfele_angriff(skill, aktive_effekte_gegner, mein_char["fraktion"])
    effekt = skill["effekt"] if schaden > 0 else None
    
    narrativ = generiere_narrative(gegner_char, mein_char, skill, wuerfel, schaden, effekt)
    print(f"\n{narrativ}")
    
    mein_char["lp"] -= schaden
    if effekt and effekt not in aktive_effekte_spieler:
        aktive_effekte_spieler.append(effekt)
        
    print(f"❤️ Deine LP: {max(0, mein_char['lp'])}/{mein_char['max_lp']} | Gegner LP: {gegner_char['lp']}/{gegner_char['max_lp']}")
    
    if mein_char["lp"] <= 0:
        print("\n💀 DU BIST GEFALLEN... Der Bot triumphiert.")
        spiel_aktiv = False
    else:
        # Dein Zug startet: Deine Effekte werden ausgewertet
        aktive_effekte_spieler = verarbeite_statuseffekte(mein_char, aktive_effekte_spieler, True)
        if mein_char["lp"] <= 0:
            print("\n💀 Du bist an deinen Statuseffekten krepiert!")
            spiel_aktiv = False
            return
        mein_zug = True
        zeige_kampf_interface()

def main():
    global conn, mein_zug, spiel_aktiv, gegner_char, bot_modus, mein_char, aktive_effekte_gegner, aktive_effekte_spieler
    
    print("Verfügbare Subklassen:")
    for k, v in SUBKLASSEN.items():
        print(f"{k} - {v['name']} (LP: {v['max_lp']}) \n    💪 Passiv: {v['passiv']}")
    
    sk_wahl = input("\nWähle deine Subklasse (1-6): ").strip()
    if sk_wahl not in SUBKLASSEN: sk_wahl = "1"
    mein_char = SUBKLASSEN[sk_wahl].copy()
    
    print("\nSpielmodus wählen:")
    print("1 - Gegen einen Bot spielen (KI)")
    print("2 - Online: Auf Verbindung warten (Host)")
    print("3 - Online: Zu anderem Gerät verbinden (Client)")
    modus = input("Modus (1-3): ").strip()
    
    if modus == "1":
        bot_modus = True
        bot_wahl = random.choice([k for k in SUBKLASSEN.keys() if SUBKLASSEN[k]["fraktion"] != mein_char["fraktion"]])
        gegner_char = SUBKLASSEN[bot_wahl].copy()
        gegner_char["name"] = "Servo-Bot [" + gegner_char["name"] + "]"
        
        print(f"\n🤖 Bot-Match gestartet gegen: {gegner_char['name']}")
        mein_zug = True
        zeige_kampf_interface()
        
    else:
        port = 50005
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        
        if modus == "2":
            local_ip = get_local_ip()
            s.bind(('0.0.0.0', port))
            s.listen(1)
            print(f"\n📡 Warte auf Verbindung auf Port {port}...\n👉 Deine IP: {local_ip}")
            conn, addr = s.accept()
            mein_zug = True  
        else:
            ip = input("IP-Adresse des Hosts: ").strip()
            s.connect((ip, port))
            conn = s
            mein_zug = False 
            
        conn.sendall(f"HELLO:{sk_wahl}".encode('utf-8'))
        empfang_thread = threading.Thread(target=empfange_daten, daemon=True)
        empfang_thread.start()
    
    while spiel_aktiv:
        if mein_zug:
            skill_wahl = input("").strip()
            if skill_wahl not in mein_char["skills"]:
                skill_wahl = "1"
                
            skill = mein_char["skills"][skill_wahl]
            wuerfel, schaden = wuerfele_angriff(skill, aktive_effekte_spieler, gegner_char["fraktion"])
            effekt = skill["effekt"] if schaden > 0 else None
            
            narrativ = generiere_narrative(mein_char, gegner_char, skill, wuerfel, schaden, effekt)
            print(f"\n{narrativ}")
            
            gegner_char["lp"] -= schaden
            if effekt and effekt not in aktive_effekte_gegner:
                aktive_effekte_gegner.append(effekt)
                
            print(f"❤️ Deine LP: {mein_char['lp']}/{mein_char['max_lp']} | Gegner LP: {max(0, gegner_char['lp'])}/{gegner_char['max_lp']}")
            
            if gegner_char["lp"] <= 0:
                print("\n🏆 SIEG! Du hast den feindlichen Anführer im Staub zerschmettert!")
                if not bot_modus: conn.sendall("ENDE:SIEG".encode('utf-8'))
                spiel_aktiv = False
                break
                
            mein_zug = False
            if bot_modus:
                # Bevor der Bot zieht, triggern seine Statuseffekte
                aktive_effekte_gegner = verarbeite_statuseffekte(gegner_char, aktive_effekte_gegner, False)
                if gegner_char["lp"] <= 0:
                    print("\n🏆 SIEG! Der Bot ist an seinen Statuseffekten verreckt!")
                    spiel_aktiv = False
                    break
                bot_turn()
            else:
                conn.sendall(f"ANGRIFF:{skill_wahl},{wuerfel},{schaden},{effekt}".encode('utf-8'))
                # Bevor der Gegner am Zug ist, laufen seine Effekte drüben automatisch ab
                print("\n⏳ Wartet auf den Zug des Gegners...")
        else:
            time.sleep(0.1)

    if conn: conn.close()

if __name__ == "__main__":
    main()
