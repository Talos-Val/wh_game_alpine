def perform_backup(faction_id, source_dir, backup_vault="~/cogitator_vault"):
    c_prm, c_sec, _, cfg = get_colors(faction_id)
    if not source_dir or not os.path.exists(source_dir):
        print(f"{c_sec}[!] Source Sanctum path '{source_dir}' does not exist.{C_END}")
        return

    print(f"{c_prm}>>> Initializing Archive Liturgy: {cfg['backup_msg']} <<<{C_END}")
    
    target_path = os.path.expanduser(backup_vault)
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    dest_file = os.path.join(target_path, f"grimdark_backup_{timestamp}.tar.gz")
    
    os.makedirs(target_path, exist_ok=True)
    
    try:
        print(f"{c_sec}  [+] Scribing files into Gzip containment...{C_END}")
        with tarfile.open(dest_file, "w:gz") as tar:
            tar.add(source_dir, arcname=os.path.basename(source_dir))
        print(f"{c_prm}  [SUCCESS] Vault creation completed. Sacred relic stored at: {dest_file}{C_END}")
    except Exception as e:
        print(f"{c_sec}  [!] Ritual interrupted! Vault generation failed: {e}{C_END}")

def purge_archives(faction_id):
    c_prm, c_sec, _, cfg = get_colors(faction_id)
    print(f"{c_prm}>>> Initiating Archive Exorcism: {cfg['purgation_msg']} <<<{C_END}")
    
    temp_dir = "/tmp"
    removed_bytes = 0
    removed_files = 0
    
    for root, _, files in os.walk(temp_dir):
        for name in files:
            filepath = os.path.join(root, name)
            try:
                if not os.path.islink(filepath):
                    file_size = os.path.getsize(filepath)
                    os.remove(filepath)
                    removed_bytes += file_size
                    removed_files += 1
            except Exception:
                pass
                
    removed_mb = round(removed_bytes / (1024 * 1024), 2)
    print(f"{c_sec}  [+] Dissolved {removed_files} corrupted files.{C_END}")
    print(f"  [+] Purged {removed_mb} MB of toxic data wastes.{C_END}")
    print(f"{c_prm}>>> Log Purge Ritual complete. <<<{C_END}\n")

def scan_warp(faction_id, target_host, ports_str):
    c_prm, c_sec, _, _ = get_colors(faction_id)
    ports = []
    try:
        ports = [int(p.strip()) for p in ports_str.split(",")]
    except ValueError:
        ports = [22, 80, 443, 8080]
        
    print(f"{c_prm}>>> Channeling psychic energy to scan Warp Portals on: {target_host} <<<{C_END}")
    
    for port in ports:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.5)
        try:
            result = s.connect_ex((target_host, port))
            if result == 0:
                print(f"  {c_prm}[OPEN PORT]{C_END} Portal {port} is {C_BOLD}ACTIVE & RECEPTIVE{C_END}")
        except Exception:
            pass
        finally:
            s.close()
    print(f"{c_prm}>>> Warp Portal Scan Completed. <<<{C_END}\n")

def inject_aliases(faction_id):
    c_prm, c_sec, _, cfg = get_colors(faction_id)
    home = os.path.expanduser("~")
    rc_files = [os.path.join(home, ".bashrc"), os.path.join(home, ".zshrc")]
    target_rc = rc_files[0]
    
    shell = os.environ.get("SHELL", "")
    if "zsh" in shell and os.path.exists(rc_files[1]):
        target_rc = rc_files[1]
        
    print(f"{c_prm}>>> Inscribing terminal aliases into {cfg['name']} dialect... <<<{C_END}")
    
    custom_aliases = {
        "gitsmash": "git push --force",
        "exorcise_cache": "sudo rm -rf /tmp/* ~/.cache/*",
        "praise_emperor": 'echo "By His Will, My Server Runs!"'
    }
    
    has_sig = False
    if os.path.exists(target_rc):
        with open(target_rc, 'r') as f:
            if "GRIMDARK_OMNIS_TOOL_ALIASES" in f.read():
                has_sig = True
                
    if has_sig:
        print(f"{c_sec}  [!] Terminal already has the Grimdark scripture. Skipping duplicate inscription.{C_END}")
        return
        
    try:
        with open(target_rc, 'a') as f:
            f.write("\n\n# === GRIMDARK_OMNIS_TOOL_ALIASES STARTED ===\n")
            for name, cmd in custom_aliases.items():
                f.write(f"alias {name}='{cmd}'\n")
                print(f"    Inscribed alias: {c_prm}{name}{C_END} -> {c_sec}{cmd}{C_END}")
            f.write("# === GRIMDARK_OMNIS_TOOL_ALIASES ENDED ===\n")
        print(f"\n[SUCCESS] Liturgies inscribed! Please run: source {target_rc}\n")
    except Exception as e:
        print(f"{c_sec}  [!] Failed to write to {target_rc}: {e}{C_END}")

