# ==========================================
# SYSTEM-ERKENNUNG
# ==========================================
def detect_system():
    """Erkennt das aktuelle Betriebssystem und die Linux-Distribution."""
    system = platform.system().lower()
    if system == "windows":
        return "windows", None
    elif system == "darwin":
        return "macos", None
    elif system == "linux":
        distro = _detect_linux_distro()
        return "linux", distro
    return "unknown", None

def _detect_linux_distro():
    """Erkennt die Linux-Distribution."""
    # Methode 1: /etc/os-release (moderner Standard)
    if os.path.exists("/etc/os-release"):
        try:
            with open("/etc/os-release") as f:
                content = f.read()
            id_match = re.search(r'^ID="?([^"\n]+)"?', content, re.MULTILINE)
            if id_match:
                distro_id = id_match.group(1).lower()
                # Distro-Familie bestimmen
                if distro_id in ("ubuntu", "debian", "linuxmint", "pop", "kali", "raspbian", "elementary"):
                    return "debian"
                elif distro_id in ("fedora", "rhel", "centos", "rocky", "almalinux", "ol"):
                    return "fedora"
                elif distro_id in ("arch", "manjaro", "endeavouros", "garuda"):
                    return "arch"
                elif distro_id in ("opensuse", "sles", "sled"):
                    return "suse"
                elif distro_id in ("alpine",):
                    return "alpine"
                elif distro_id in ("void",):
                    return "void"
                else:
                    return distro_id
        except Exception:
            pass
    # Methode 2: Klassische Release-Dateien
    for path, name in [("/etc/debian_version", "debian"), ("/etc/fedora-release", "fedora"),
                       ("/etc/arch-release", "arch"), ("/etc/alpine-release", "alpine")]:
        if os.path.exists(path):
            return name
    return "unknown"

def get_package_manager_info(distro):
    """Gibt Paketmanager-Infos für die jeweilige Distribution zurück."""
    pm_map = {
        "debian":  {"cmd": "apt",    "install": "sudo apt install -y",  "pkg_ffmpeg": "ffmpeg", "pkg_python": "python3-pip"},
        "fedora":  {"cmd": "dnf",    "install": "sudo dnf install -y",  "pkg_ffmpeg": "ffmpeg", "pkg_python": "python3-pip"},
        "arch":    {"cmd": "pacman", "install": "sudo pacman -S --noconfirm", "pkg_ffmpeg": "ffmpeg", "pkg_python": "python-pip"},
        "suse":    {"cmd": "zypper", "install": "sudo zypper install -y", "pkg_ffmpeg": "ffmpeg", "pkg_python": "python3-pip"},
        "alpine":  {"cmd": "apk",   "install": "sudo apk add",          "pkg_ffmpeg": "ffmpeg", "pkg_python": "py3-pip"},
        "void":    {"cmd": "xbps",  "install": "sudo xbps-install -y",  "pkg_ffmpeg": "ffmpeg", "pkg_python": "python3-pip"},
    }
    return pm_map.get(distro, {"cmd": "apt", "install": "sudo apt install -y", "pkg_ffmpeg": "ffmpeg", "pkg_python": "python3-pip"})

SYSTEM_OS, SYSTEM_DISTRO = detect_system()

