def get_system_telemetry(faction_id):
    c_prm, c_sec, c_acc, cfg = get_colors(faction_id)
    print(f"{c_prm}>>> Running diagnostics: {cfg['telemetry_header']} <<<{C_END}\n")
    
    hostname = socket.gethostname()
    username = getpass.getuser()
    
    # Memory Info
    mem_total, mem_used, mem_free = 0, 0, 0
    if os.path.exists('/proc/meminfo'):
        with open('/proc/meminfo', 'r') as f:
            for line in f:
                if 'MemTotal' in line:
                    mem_total = int(line.split()[1]) // 1024
                elif 'MemFree' in line:
                    mem_free = int(line.split()[1]) // 1024
                elif 'Cached' in line:
                    mem_free += int(line.split()[1]) // 1024
        mem_used = mem_total - mem_free

    # CPU Load
    cpu_load = "Unknown"
    if os.path.exists('/proc/loadavg'):
        with open('/proc/loadavg', 'r') as f:
            cpu_load = f.read().strip().split()[0]
            
    # Disk Info
    disk_total, disk_used = 0, 0
    try:
        total, used, _ = shutil.disk_usage("/")
        disk_total = total // (2**30)
        disk_used = used // (2**30)
    except Exception:
        pass

    if faction_id == "custodes":
        print(f"{c_sec}[TERRA LOG] Cogitator Scribe: {C_BOLD}{username}@{hostname}{C_END}")
        print(f"  Shield Protection Memory: {mem_used} MB / {mem_total} MB Used")
        print(f"  Imperial Core CPU Pressure: {cpu_load}")
        print(f"  Sanctuary Storage: {disk_used} GB / {disk_total} GB Occupied")
    elif faction_id == "thousand_sons":
        print(f"{c_sec}[SCROLL LOG] Acolyte Host: {C_BOLD}{username}@{hostname}{C_END}")
        print(f"  Aura Memory Flux: {mem_used} MB / {mem_total} MB")
        print(f"  Tzeentch Whispers (CPU Load): {cpu_load}")
        print(f"  Librarium Grimoire Disk: {disk_used} GB / {disk_total} GB")
    elif faction_id == "orks":
        print(f"{c_sec}[DA BOYZ LOG] Mek Driver: {C_BOLD}{username}@{hostname}{C_END}")
        print(f"  FUEL DRUM SIZE (RAM): {mem_used} SQUIGS / {mem_total} SQUIGS IN USE")
        print(f"  ENGINE THROTTLE (CPU): {cpu_load} DAKKAS")
        print(f"  SCRAP YARD SPACE (DISK): {disk_used} BINS / {disk_total} BINS FULL")
    elif faction_id == "night_lords":
        print(f"{c_sec}[STALKER LOG] Prey Machine: {C_BOLD}{username}@{hostname}{C_END}")
        print(f"  Captured Soul Memory: {mem_used} MB / {mem_total} MB Bound")
        print(f"  Anxiety Levels (CPU): {cpu_load}")
