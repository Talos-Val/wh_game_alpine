#!/usr/bin/env python3
import socket
import threading
import sys
import time
import random

# Globale Variablen für die Netzwerkverbindung
conn = None
mein_zug = False
spiel_aktiv = True
bot_modus = False

# Charakter-Auswahl
fraktionen = {
    "1": {"name": "Goff Ork Garboss", "lp": 8, "type": "orks"},
    "2": {"name": "Rubric Sorcerer", "lp": 6, "type": "ts"},
    "3": {"name": "Night Lords Raptor", "lp": 7, "type": "nl"}
}

print("\n💀 WARHAMMER CLI ARENA 💀\n")
print("Wähle deine Fraktion:")
for k, v in fraktionen.items():
    print(f"{k} - {v['name']}")
wahl = input("Deine Wahl (1-3): ").strip()
if wahl not in fraktionen: wahl = "1"

mein_char = fraktionen[wahl]
gegner_char = {"name": "Unbekannt", "lp": 0, "type": "unknown"}

def wuerfele_schaden(angreifer_type, verteidiger_type):
    # Night Lords Erschwernis
    ziel_wert = 4 if verteidiger_type == "nl" else 3
    
    wuerfel = random.randint(1, 6)
    schaden = 0
    extra_text = ""
    
    if wuerfel >= ziel_wert:
        schaden = 2
        # Ork Bonus bei einer 6
        if wuerfel == 6 and angreifer_type == "orks":
            extra_text = " (💥 WAAAGH! Bonus-Dakka!)"
            bonus_wuerfel = random.randint(1, 6)
            if bonus_wuerfel >= ziel_wert:
                schaden += 2
    
    return wuerfel, schaden, extra_text

def empfange_daten():
    global conn, mein_zug, spiel_aktiv, gegner_char
    while spiel_aktiv:
        try:
            daten = conn.recv(1024).decode('utf-8')
            if not daten: break
            
            befehl, wert = daten.split(":", 1)
            
            if befehl == "HELLO":
                name, g_type = wert.split(",", 1)
                gegner_char["name"] = name
                gegner_char["type"] = g_type
                print(f"\n🤝 Verbindung steht! Dein Gegner ist: {gegner_char['name']}")
                if mein_zug:
                    print("\n⚔️ Du bist am Zug! Tippe 'schlagen' zum Angreifen.")
            
            elif befehl == "ANGRIFF":
                schaden = int(wert)
                mein_char["lp"] -= schaden
                print(f"\n💥 {gegner_char['name']} greift an und macht {schaden} Schaden!")
                print(f"❤️ Deine verbleibenden LP: {max(0, mein_char['lp'])}")
                
                if mein_char["lp"] <= 0:
                    print("\n💀 DU BIST GEFALLEN... Der Feind triumphiert.")
                    conn.sendall("ENDE:VERLOREN".encode('utf-8'))
                    spiel_aktiv = False
                    break
                
                mein_zug = True
                print("\n⚔️ Du bist am Zug! Tippe 'schlagen' zum Angreifen.")
                
            elif befehl == "ENDE":
                print("\n🏆 SIEG! Der Feind wurde vernichtet!")
                spiel_aktiv = False
                break
        except:
            break

def get_local_ip():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(('10.255.255.255', 1))
        ip = s.getsockname()[0]
    except Exception:
        ip = '127.0.0.1'
    finally:
        s.close()
    return ip

def bot_turn():
    global mein_zug, spiel_aktiv
    print(f"\n🤖 {gegner_char['name']} überlegt...")
    time.sleep(1.5)
    
    # Thousand Sons Psi-Schaden vorweg
    if gegner_char["type"] == "ts":
        print("🔮 Warp-Blitze zucken! Tödlicher Psi-Schaden.")
        mein_char["lp"] -= 1
        print(f"💥 Du verlierst 1 LP durch Hexerei! (Deine LP: {max(0, mein_char['lp'])})")
        if mein_char["lp"] <= 0:
            print("\n💀 DU BIST GEFALLEN... Die KI triumphiert.")
            spiel_aktiv = False
            return

    wuerfel, schaden, extra = wuerfele_schaden(gegner_char["type"], mein_char["type"])
    
    if schaden > 0:
        print(f"🎲 Bot würfelt: {wuerfel} -> Treffer!{extra} Er macht {schaden} Schaden.")
        mein_char["lp"] -= schaden
    else:
        print(f"🎲 Bot würfelt: {wuerfel} -> Daneben!")
        
    print(f"❤️ Deine verbleibenden LP: {max(0, mein_char['lp'])}")
    
    if mein_char["lp"] <= 0:
        print("\n💀 DU BIST GEFALLEN... Die KI triumphiert.")
        spiel_aktiv = False
    else:
        mein_zug = True
        print("\n⚔️ Du bist am Zug! Tippe 'schlagen' zum Angreifen.")

def main():
    global conn, mein_zug, spiel_aktiv, gegner_char, bot_modus
    
    print("\nSpielmodus wählen:")
    print("1 - Gegen einen Bot spielen (KI)")
    print("2 - Online: Auf Verbindung warten (Host)")
    print("3 - Online: Zu anderem Gerät verbinden (Client)")
    modus = input("Modus (1-3): ").strip()
    
    if modus == "1":
        bot_modus = True
        # Bot wählt zufällige andere Fraktion
        bot_wahl = random.choice([k for k in fraktionen.keys() if k != wahl])
        gegner_char = fraktionen[bot_wahl].copy()
        gegner_char["name"] = "Servo-Bot [" + gegner_char["name"] + "]"
        
        print(f"\n🤖 Bot-Match gestartet gegen: {gegner_char['name']}")
        mein_zug = True
        print("\n⚔️ Du bist am Zug! Tippe 'schlagen' zum Angreifen.")
        
    else:
        port = 50005
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        
        if modus == "2":
            local_ip = get_local_ip()
            s.bind(('0.0.0.0', port))
            s.listen(1)
            print(f"\n📡 Warte auf Verbindung auf Port {port}...")
            print(f"👉 Deine IP-Adresse lautet: {local_ip}")
            conn, addr = s.accept()
            mein_zug = True  
        else:
            ip = input("Gib die IP-Adresse des anderen Geräts ein: ").strip()
            s.connect((ip, port))
            conn = s
            mein_zug = False 
            
        # Start-Daten austauschen (Name + Fraktionstyp)
        conn.sendall(f"HELLO:{mein_char['name']},{mein_char['type']}".encode('utf-8'))
        
        empfang_thread = threading.Thread(target=empfange_daten, daemon=True)
        empfang_thread.start()
    
    # Hauptschleife für das Spiel
    while spiel_aktiv:
        if mein_zug:
            aktion = input("> ").strip().lower()
            if aktion == "schlagen":
                # Thousand Sons Spieler Psi-Phase
                if mein_char["type"] == "ts":
                    print("🔮 Deine Hexerei fügt dem Feind 1 garantierten Schaden zu!")
                    gegner_char["lp"] -= 1
                    print(f"💥 Gegner verbleibende LP: {max(0, gegner_char['lp'])}")
                    if gegner_char["lp"] <= 0:
                        print("\n🏆 SIEG! Der Feind wurde vernichtet!")
                        if not bot_modus: conn.sendall("ENDE:SIEG".encode('utf-8'))
                        spiel_aktiv = False
                        break
                
                # Normaler Angriffswurf
                wuerfel, schaden, extra = wuerfele_schaden(mein_char["type"], gegner_char["type"])
                
                if schaden > 0:
                    print(f"🎲 Gewürfelt: {wuerfel} -> Treffer!{extra} Du machst {schaden} Schaden.")
                    gegner_char["lp"] -= schaden
                else:
                    print(f"🎲 Gewürfelt: {wuerfel} -> Daneben!")
                    
                print(f"🍏 Gegner verbleibende LP: {max(0, gegner_char['lp'])}")
                
                if gegner_char["lp"] <= 0:
                    print("\n🏆 SIEG! Der Feind wurde vernichtet!")
                    if not bot_modus: conn.sendall("ENDE:SIEG".encode('utf-8'))
                    spiel_aktiv = False
                    break
                
                mein_zug = False
                
                if bot_modus:
                    bot_turn()
                else:
                    conn.sendall(f"ANGRIFF:{schaden}".encode('utf-8'))
                    print("⏳ Wartet auf den Zug des Gegners...")
        else:
            time.sleep(0.1)

    if conn:
        conn.close()

if __name__ == "__main__":
    main()
