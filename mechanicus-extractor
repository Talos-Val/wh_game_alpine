                ydl.download([user_input])
            print(f"\n{G}✓ [ERFOLG] Audio extrahiert und im Schrein versiegelt!{W}")
        except Exception as e:
            print(f"{R}[KATASTROPHE] Download fehlgeschlagen: {e}{W}")
        return
    # ─────────────────────────────────────────────────────────────────────

    search_query = user_input
    artist_folder = "Unbekannter_Saenger"

    # Hochpräzise Spotify-Parsing-Matrix (v15.0)
    if "spotify.com" in user_input or "spotify.link" in user_input:
        print(f"\n{Y}[LOG] Spotify-Protokoll erkannt. Starte Multi-Vektor-Extraktion...{W}")
        
        artist_name, song_title = extract_spotify_metadata(user_input, requests)
        
        if song_title:
            print(f"{G}[STATUS] Spotify-Titel erkannt: '{song_title}'{W}")
        else:
            print(f"{R}[WARNUNG] Kein Titel extrahierbar. Roheingabe wird genutzt.{W}")
            song_title = input(f"{Y}» Song-Titel manuell eingeben: {W}").strip() or "Unbekannter_Track"

        # Künstler IMMER manuell bestätigen — Automatik ist zu fehleranfällig
