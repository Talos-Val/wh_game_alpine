# ==========================================
# SPOTIFY METADATEN-EXTRAKTOR (v15.0 - Mehrstufig)
# ==========================================
def extract_spotify_metadata(user_input, requests):
    """
    Extrahiert Künstler und Titel aus einem Spotify-Link.
    Verwendet mehrere Methoden als Fallback-Kette.
    Gibt (artist_name, song_title) zurück oder (None, None) bei Fehler.
    """
    artist_name = None
    song_title = None

    # -- Methode 1: Spotify oEmbed API --
    # Normalisiere den Link (entferne intl-XX Präfix, das die API manchmal stört)
    clean_url = re.sub(r'open\.spotify\.com/intl-[a-z]+/', 'open.spotify.com/', user_input)
    # Extrahiere nur Track-ID falls vorhanden
    track_id_match = re.search(r'/track/([A-Za-z0-9]+)', user_input)
    if track_id_match:
        track_id = track_id_match.group(1)
        canonical_url = f"https://open.spotify.com/track/{track_id}"
    else:
        canonical_url = clean_url

    try:
        oembed_url = f"https://open.spotify.com/oembed?url={canonical_url}"
        resp = requests.get(oembed_url, headers=BROWN_GEAR_HEADERS, timeout=10)
        if resp.status_code == 200:
            data = resp.json()
            raw_title = data.get("title", "").strip()
            
            # Spotify oEmbed title-Format ist MEISTENS: "Songname"
            # Manchmal: "Künstler - Songname" (Künstler zuerst!)
            # Selten: "Songname · Künstler"
            # Wir behandeln raw_title erstmal nur als Songtitel-Kandidat,
            # OHNE daraus einen Künstler zu extrahieren — das ist zu fehleranfällig.
            # Der Künstler wird ausschließlich aus HTML/strukturierten Daten geholt.
            song_title = raw_title  # Kandidat, wird ggf. durch HTML-Methoden überschrieben
            # KEIN artist_name aus oEmbed-Titel ableiten — zu fehleranfällig!
    except Exception as e:
        print(f"{Y}[LOG] oEmbed-Methode nicht verfügbar: {e}{W}")

    # -- Methode 2: Spotify Open Graph / HTML Scraping --
    if not artist_name and track_id_match:
        try:
            track_id = track_id_match.group(1)
            # Verwende den kanonischen Link ohne intl-Präfix
            page_url = f"https://open.spotify.com/track/{track_id}"
            # Verwende Accept-Language Deutsch, um konsistente Ergebnisse zu bekommen
            headers = {**BROWN_GEAR_HEADERS, 'Accept-Language': 'de-DE,de;q=0.9'}
            page_resp = requests.get(page_url, headers=headers, timeout=15)
            html = page_resp.text

            # Priorität 1: JSON-LD Strukturdaten (zuverlässigste Methode)
            jsonld_match = re.search(r'<script type="application/ld\+json">(.*?)</script>', html, re.DOTALL)
            if jsonld_match:
                try:
                    ld_data = json.loads(jsonld_match.group(1))
                    if isinstance(ld_data, dict):
                        # MusicRecording Schema
                        if ld_data.get("@type") == "MusicRecording":
                            song_title = song_title or ld_data.get("name", "")
                            by_artist = ld_data.get("byArtist", {})
                            if isinstance(by_artist, list) and by_artist:
                                artist_name = by_artist[0].get("name", "")
                            elif isinstance(by_artist, dict):
                                artist_name = by_artist.get("name", "")
                except json.JSONDecodeError:
                    pass

            # Priorität 2: Next.js / React Hydration Data (Spotify nutzt Next.js)
            if not artist_name:
                # Neues Format: "__NEXT_DATA__" Script-Tag
                next_data_match = re.search(r'<script id="__NEXT_DATA__"[^>]*>(.*?)</script>', html, re.DOTALL)
                if next_data_match:
                    try:
                        nd = json.loads(next_data_match.group(1))
                        # Navigiere durch die verschachtelte Struktur
                        entity = (nd.get("props", {})
                                    .get("pageProps", {})
                                    .get("state", {})
                                    .get("data", {})
                                    .get("entity", {}))
                        if not entity:
                            # Alternativer Pfad
                            entity = (nd.get("props", {})
                                        .get("pageProps", {})
                                        .get("data", {}))
                        if entity:
                            song_title = song_title or entity.get("name", "") or entity.get("title", "")
                            artists = entity.get("artists", {})
                            if isinstance(artists, dict):
                                items = artists.get("items", [])
                                if items:
                                    artist_name = items[0].get("profile", {}).get("name", "")
                            elif isinstance(artists, list) and artists:
                                artist_name = artists[0].get("name", "")
                    except (json.JSONDecodeError, AttributeError):
                        pass

            # Priorität 3: Open Graph Meta-Tags
            if not artist_name:
                og_title = re.search(r'<meta property="og:title" content="([^"]+)"', html)
                og_desc = re.search(r'<meta property="og:description" content="([^"]+)"', html)
                if og_title and not song_title:
                    song_title = og_title.group(1).strip()
                if og_desc:
                    # Description ist oft: "Lied · Künstler · Album · Jahr"
                    desc = og_desc.group(1)
                    parts = desc.split(" · ")
                    if len(parts) >= 2:
                        if not song_title:
                            song_title = parts[0].strip()
                        artist_name = parts[1].strip()

            # Priorität 4: Twitter Card Meta-Tags
            if not artist_name:
                tw_artist = re.search(r'<meta name="twitter:audio:artist_name" content="([^"]+)"', html)
                tw_title  = re.search(r'<meta name="twitter:title" content="([^"]+)"', html)
                if tw_artist:
                    artist_name = tw_artist.group(1).strip()
                if tw_title and not song_title:
                    song_title = tw_title.group(1).strip()

        except Exception as e:
            print(f"{Y}[LOG] HTML-Scraping-Methode fehlgeschlagen: {e}{W}")

    # -- Methode 3: MusicBrainz (öffentliche API, kein API-Key nötig) --
    if not artist_name and track_id_match and song_title:
        try:
            # Suche über Song-Titel bei MusicBrainz
            mb_url = f"https://musicbrainz.org/ws/2/recording/?query=recording:{requests.utils.quote(song_title)}&fmt=json&limit=1"
            mb_resp = requests.get(mb_url, headers={'User-Agent': 'MechanicusExtractor/15.0 (contact@example.com)'}, timeout=10)
            if mb_resp.status_code == 200:
                mb_data = mb_resp.json()
                recordings = mb_data.get("recordings", [])
                if recordings:
                    credits = recordings[0].get("artist-credit", [])
                    if credits:
                        artist_name = credits[0].get("artist", {}).get("name", "")
        except Exception:
            pass

    return artist_name, song_title

